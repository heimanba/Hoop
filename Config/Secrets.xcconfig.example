// Required
AUTH_EMAIL = parent@example.com
AUTH_PASSWORD = <your-auth-password>

// Optional
USER_DISPLAY_NAME = Hoop 家长
USER_ID = local-parent

// Required for AI analysis
DASHSCOPE_API_KEY = <your-dashscope-api-key>

// Optional
AI_ANALYSIS_BASE_URL = https:/$()/dashscope.aliyuncs.com/compatible-mode/v1
AI_ANALYSIS_MODEL = qwen3.6-plus

// Required for OSS upload
OSS_ACCESS_KEY_ID = <your-oss-access-key-id>
OSS_ACCESS_KEY_SECRET = <your-oss-access-key-secret>
OSS_BUCKET = <your-oss-bucket>
OSS_ENDPOINT = oss-cn-hangzhou.aliyuncs.com
OSS_REGION = cn-hangzhou

// Optional for OSS upload
OSS_UPLOAD_DIR = training-videos
OSS_PUBLIC_BASE_URL =
